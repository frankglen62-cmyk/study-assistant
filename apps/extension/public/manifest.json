{
  "manifest_version": 3,
  "name": "Admin-Managed AI Study Assistant",
  "description": "Admin-controlled AI study assistance with secure pairing, side panel answers, and explicit active-tab analysis.",
  "version": "0.1.89",
  "minimum_chrome_version": "116",
  "action": {
    "default_title": "Open Study Assistant",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "alarms",
    "scripting",
    "sidePanel",
    "storage",
    "tabs"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/onboarding/index.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
